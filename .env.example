# Configurazione Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Configurazione SMTP per il reset password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tua-email@gmail.com
SMTP_PASS=tua-password-applicazione

# URL base dell'applicazione
BASE_URL=https://your-railway-app.railway.app

# CORS Origins (comma-separated)
CORS_ORIGINS=https://your-railway-app.railway.app,http://localhost:3000

# Porta (Railway la setta automaticamente)
PORT=3000

# Ambiente
NODE_ENV=production

# Session Secret (genera una stringa casuale sicura)
SESSION_SECRET=your-random-secret-key-change-this
